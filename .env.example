# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application Client ID
CLIENT_ID=your_client_id_here

# Google Gemini API Key (free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use on startup (optional — defaults to gemini-1.5-flash if not set)
# You can also switch models at runtime with /setmodel without restarting the bot.
# Free tier options (fastest to most capable):
#   gemini-2.0-flash-lite
#   gemini-1.5-flash-8b
#   gemini-1.5-flash          ← recommended default
#   gemini-2.0-flash
#   gemini-1.5-pro
#   gemini-2.5-flash-preview-05-20
GEMINI_MODEL=gemini-1.5-flash

# Your Discord User ID (optional but recommended)
# If set, only YOU can use /setmodel. If left blank, anyone with Manage Server permission can.
# To find your ID: Discord Settings → Advanced → Enable Developer Mode, then right-click your name → Copy ID
DISCORD_OWNER_ID=your_discord_user_id_here
