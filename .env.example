# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application Client ID
CLIENT_ID=your_client_id_here

# Google Gemini API Key (free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use on startup (optional — defaults to gemini-3.1-flash-lite if not set)
# Switch models at runtime with /setmodel without restarting the bot.
#
# Gemini 3 series (recommended):
#   gemini-3.5-flash              ← most capable, stable (best judging quality)
#   gemini-3-flash-preview        ← Gemini 3 Flash, preview
#   gemini-3.1-flash-lite         ← lightest Gemini 3, stable (default)
#   gemini-3.1-pro-preview        ← most advanced, preview
#
# Gemini 2.5 series:
#   gemini-2.5-flash              ← best price-performance
#   gemini-2.5-pro                ← most capable 2.5
#
# Gemma 4 open models:
#   gemma-4-27b-it
#   gemma-4-31b-it
GEMINI_MODEL=gemini-3.1-flash-lite

# Your Discord User ID (optional but recommended)
# If set, only YOU can use /setmodel. If left blank, anyone with Manage Server can.
# To find your ID: Discord Settings → Advanced → Enable Developer Mode → right-click name → Copy ID
DISCORD_OWNER_ID=your_discord_user_id_here
